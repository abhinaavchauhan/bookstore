<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Reset Password</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Enter your new password below.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div
            class="bg-white dark:bg-slate-800 py-8 px-4 shadow-xl rounded-2xl sm:px-10 border border-slate-100 dark:border-slate-700 transition-colors">
            <form id="resetPasswordForm" class="space-y-6">
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300">New
                        Password</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" required minlength="6"
                            class="input-field shadow-sm placeholder-slate-400 text-slate-900">
                    </div>
                </div>

                <div>
                    <label for="confirmPassword"
                        class="block text-sm font-medium text-slate-700 dark:text-slate-300">Confirm Password</label>
                    <div class="mt-1">
                        <input id="confirmPassword" name="confirmPassword" type="password" required minlength="6"
                            class="input-field shadow-sm placeholder-slate-400 text-slate-900">
                    </div>
                </div>

                <div id="messageBox" class="p-3 rounded-lg text-sm hidden flex items-center gap-2 border">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"></svg>
                    <span></span>
                </div>

                <div>
                    <button type="submit"
                        class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-lg shadow-brand-500/20 text-sm font-medium text-white bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-700 hover:to-brand-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all transform hover:-translate-y-0.5">
                        Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        const msgBox = document.getElementById('messageBox');
        const btn = e.target.querySelector('button');

        if (password !== confirmPassword) {
            msgBox.className = 'p-3 rounded-lg text-sm flex items-center gap-2 border bg-red-50 text-red-700 border-red-200';
            msgBox.querySelector('svg').innerHTML = '<path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />';
            msgBox.querySelector('span').textContent = 'Passwords do not match.';
            msgBox.classList.remove('hidden');
            return;
        }

        const originalText = btn.textContent;
        btn.textContent = 'Updating...';
        btn.disabled = true;

        try {
            // Get token from URL
            const pathParts = window.location.pathname.split('/');
            const token = pathParts[pathParts.length - 1];

            const API_BASE = `http://${window.location.hostname}:5000/api`;
            const response = await axios.put(`${API_BASE}/auth/resetpassword/${token}`, { password });

            // Success
            msgBox.className = 'p-3 rounded-lg text-sm flex items-center gap-2 border bg-green-50 text-green-700 border-green-200';
            msgBox.querySelector('svg').innerHTML = '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />';
            msgBox.querySelector('span').textContent = 'Password reset successful! Redirecting to login...';
            msgBox.classList.remove('hidden');

            setTimeout(() => {
                window.location.href = '/login';
            }, 2000);

        } catch (error) {
            console.error(error);
            // Error
            msgBox.className = 'p-3 rounded-lg text-sm flex items-center gap-2 border bg-red-50 text-red-700 border-red-200';
            msgBox.querySelector('svg').innerHTML = '<path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />';
            msgBox.querySelector('span').textContent = error.response?.data?.message || 'Failed to reset password.';
            msgBox.classList.remove('hidden');
        } finally {
            btn.textContent = originalText;
            btn.disabled = false;
        }
    });
</script>