<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bookstore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        /* High-End Premium Preloader */
        #preloader {
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10000;
            overflow: hidden;
            transition: all 1s cubic-bezier(0.7, 0, 0.3, 1);
        }

        #preloader.fade-out {
            opacity: 0;
            transform: scale(1.1);
            pointer-events: none;
        }

        /* Animated Mesh Background */
        .loader-bg-glow {
            position: absolute;
            width: 150%;
            height: 150%;
            background: radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.15) 0%, transparent 50%);
            animation: moveGlow 10s infinite alternate ease-in-out;
            z-index: -1;
        }

        @keyframes moveGlow {
            0% { transform: translate(-10%, -10%); }
            100% { transform: translate(10%, 10%); }
        }

        /* Realistic 3D Book Animation */
        .book-wrapper {
            width: 120px;
            height: 90px;
            position: relative;
            transform-style: preserve-3d;
            transform: rotateX(30deg) rotateY(-10deg);
            animation: bookFloat 4s infinite ease-in-out;
            margin-bottom: 3rem;
        }

        @keyframes bookFloat {
            0%, 100% { transform: rotateX(30deg) rotateY(-10deg) translateY(0); }
            50% { transform: rotateX(35deg) rotateY(-5deg) translateY(-15px); }
        }

        .book-cover {
            position: absolute;
            width: 60px;
            height: 90px;
            background: #0ea5e9;
            border-radius: 2px 5px 5px 2px;
            transform-origin: right;
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: inset 3px 0 10px rgba(0,0,0,0.2);
        }

        .book-cover.left {
            left: 0;
            transform: rotateY(-180deg);
            background: #0284c7;
        }

        .book-cover.right {
            left: 60px;
            transform-origin: left;
            background: #0284c7;
        }

        .book-page-css {
            position: absolute;
            width: 58px;
            height: 84px;
            top: 3px;
            left: 60px;
            background: #f8fafc;
            transform-origin: left;
            border-radius: 0 3px 3px 0;
            box-shadow: inset 0 0 5px rgba(0,0,0,0.1);
            animation: pageFlip 3s infinite var(--delay) cubic-bezier(0.1, 0, 0.3, 1);
            z-index: 10;
        }

        @keyframes pageFlip {
            0% { transform: rotateY(0deg); }
            80% { transform: rotateY(-180deg); }
            100% { transform: rotateY(-180deg); }
        }

        .book-spine {
            position: absolute;
            width: 4px;
            height: 90px;
            left: 58px;
            background: #075985;
            transform: translateZ(-1px);
        }

        /* Staggered Letter Animation */
        .loader-brand {
            display: flex;
            gap: 4px;
        }

        .loader-letter {
            font-family: 'Outfit', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            color: white;
            opacity: 0;
            transform: translateY(20px);
            animation: letterEntry 0.6s forwards var(--delay) cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: linear-gradient(135deg, #fff 0%, #0ea5e9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.05em;
        }

        @keyframes letterEntry {
            to { opacity: 1; transform: translateY(0); }
        }

        .loader-progress {
            width: 200px;
            height: 2px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            margin-top: 1.5rem;
            position: relative;
            overflow: hidden;
        }

        .loader-progress-inner {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0%;
            background: #0ea5e9;
            box-shadow: 0 0 10px #0ea5e9;
            animation: fillProgress 1.5s forwards cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes fillProgress {
            to { width: 100%; }
        }
    </style>

    <script>
        // Dark Mode Initialization
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <script>
        // Simple client-side auth state management
        document.addEventListener('DOMContentLoaded', () => {
            const token = localStorage.getItem('token');
            const user = JSON.parse(localStorage.getItem('user') || '{}');

            if (token) {
                document.querySelectorAll('.auth-hidden').forEach(el => el.style.display = 'none');
                document.querySelectorAll('.auth-visible').forEach(el => {
                    // Remove inline display:none to let CSS take over (block, flex, etc)
                    el.style.display = '';
                    // If it was hidden by a class like 'hidden', we might need to remove that too, 
                    // but our HTML mostly uses inline style="display:none" for auth-visible.
                    // However, some might need explicit block/flex if they lack classes.
                    // Let's check if it remains hidden (computed).
                    // If it was hidden by a class like 'hidden' (Tailwind), we should respect that (e.g. desktop menu on mobile).
                    // Only force display if it's NOT hidden by a class but strangely hidden for other reasons.
                    if (getComputedStyle(el).display === 'none' && !el.classList.contains('hidden')) {
                        el.style.display = el.tagName === 'SPAN' || el.tagName === 'A' ? 'inline-block' : 'block';
                    }
                });

                if (user.name) {
                    const nameEl = document.getElementById('userNameDisplay');
                    if (nameEl) nameEl.textContent = user.name;
                    const mobileNameEl = document.getElementById('mobileUserNameDisplay');
                    if (mobileNameEl) mobileNameEl.textContent = user.name;
                    const dropdownNameEl = document.getElementById('dropdownUserName');
                    if (dropdownNameEl) dropdownNameEl.textContent = user.name;
                }
                if (user.role === 'admin') {
                    document.querySelectorAll('.admin-visible').forEach(el => el.style.display = 'block'); // Admin link is usually block in mobile or inline in desktop logic
                    // Better:
                    document.querySelectorAll('.admin-visible').forEach(el => el.style.display = '');
                }
            } else {
                document.querySelectorAll('.auth-hidden').forEach(el => el.style.display = ''); // Revert to CSS (flex)
                document.querySelectorAll('.auth-visible').forEach(el => el.style.display = 'none');
                document.querySelectorAll('.admin-visible').forEach(el => el.style.display = 'none');
            }
        });

        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/login';
        }

        document.addEventListener('DOMContentLoaded', () => {
            const themeToggle = document.getElementById('themeToggle');

            // Initialize switch state
            if (themeToggle) {
                if (document.documentElement.classList.contains('dark')) {
                    themeToggle.checked = true;
                }

                themeToggle.addEventListener('change', () => {
                    if (themeToggle.checked) {
                        document.documentElement.classList.add('dark');
                        localStorage.theme = 'dark';
                    } else {
                        document.documentElement.classList.remove('dark');
                        localStorage.theme = 'light';
                    }
                });
            }

            // Mobile Menu Toggle
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');

            if (mobileMenuBtn && mobileMenu) {
                mobileMenuBtn.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }
        });

        // Global Cart Count Update
        async function updateCartCount() {
            const token = localStorage.getItem('token');
            if (!token) return;

            try {
                // Determine API URL based on current hostname to support both localhost and network IP
                const API_BASE = `http://${window.location.hostname}:5000/api`;
                const response = await axios.get(`${API_BASE}/cart`, {
                    headers: { Authorization: `Bearer ${token}` }
                });
                const cart = response.data.data;
                const count = cart ? cart.items.length : 0;

                const badge = document.getElementById('cartCount');
                if (badge) {
                    badge.textContent = count;
                    badge.classList.remove('hidden');
                    if (count === 0) badge.classList.add('hidden');
                }
            } catch (error) {
                console.error('Failed to update cart count', error);
            }
        }

        // Call on load if logged in
        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('token')) {
                updateCartCount();
            }
        });

        // Preloader Control
        (function() {
            window.addEventListener('load', () => {
                const preloader = document.getElementById('preloader');
                if (!preloader) return;

                const navEntries = performance.getEntriesByType('navigation');
                const isReload = navEntries.length > 0 && navEntries[0].type === 'reload';
                const isFirstVisit = !sessionStorage.getItem('hasSeenLoader');

                if (isReload || isFirstVisit) {
                    // Show full animation
                    sessionStorage.setItem('hasSeenLoader', 'true');
                    setTimeout(() => {
                        preloader.classList.add('fade-out');
                        setTimeout(() => preloader.style.display = 'none', 1000);
                    }, 1800);
                } else {
                    // Hide instantly for normal navigation
                    preloader.style.transition = 'none';
                    preloader.style.display = 'none';
                }
            });
        })();
    </script>
</head>

