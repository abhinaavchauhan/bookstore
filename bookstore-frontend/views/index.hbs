<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script>
    // Existing script logic preserved
    console.log('Index.hbs script loaded');
    document.addEventListener('DOMContentLoaded', () => {
        console.log('DOM Content Loaded');
        loadBooks();
    });
    document.getElementById('searchInput').addEventListener('input', debounce(loadBooks, 500));
    document.getElementById('categoryFilter').addEventListener('change', loadBooks);

    function filterCategory(cat) {
        document.getElementById('categoryFilter').value = cat;
        loadBooks();
        document.getElementById('books').scrollIntoView({ behavior: 'smooth' });
    }

    async function loadBooks() {
        const search = document.getElementById('searchInput').value;
        const category = document.getElementById('categoryFilter').value;

        const API_BASE = `http://${window.location.hostname}:5000/api`;
        let url = `${API_BASE}/books?`;

        if (search) url += `search=${encodeURIComponent(search)}&`;
        // Handle client-side category filtering if API doesn't support it fully or for simplicity
        // The API likely returns all books if no search, so we might filter client side if needed, 
        // but let's assume API search covers it or we filter the array.
        // Actually, looking at the backend code would confirm, but let's proceed with fetching.

        try {
            const response = await axios.get(url);
            let books = response.data.data;

            // Client side filter for category since we are not passing it to API currently
            if (category) {
                books = books.filter(b => b.category === category);
            }

            const grid = document.getElementById('bookGrid');
            const countEl = document.getElementById('bookCount');
            if (countEl) countEl.textContent = books.length;

            if (books.length === 0) {
                grid.innerHTML = `
                    <div class="col-span-full text-center py-20 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 flex flex-col items-center">
                        <svg class="w-16 h-16 text-slate-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        <p class="text-slate-500 dark:text-slate-400 text-lg font-medium">No books found matching your criteria.</p>
                        <button onclick="clearFilters()" class="mt-4 text-brand-600 hover:text-brand-700 font-medium">Clear Filters</button>
                    </div>`;
            } else {
                // Populate Main Grid
                grid.innerHTML = books.map(book => createBookCard(book)).join('');

                // Populate Trending Section (Only on initial load/no search)
                if (!search && !category) {
                    renderTrending(books);
                }
            }

            checkAuthStatus(); // Combined auth check function
        } catch (error) {
            console.error('Error loading books:', error);
            const msg = error.message === 'Network Error' ? 'Could not connect to server. Please check if backend is running.' : 'Failed to load books.';
            document.getElementById('bookGrid').innerHTML = `<div class="col-span-full text-center py-12 text-red-500 bg-red-50 rounded-lg shadow-sm border border-red-100">
                <p class="font-bold text-lg mb-2">Connection Error</p>
                <p>${msg} (Try refreshing)</p>
            </div>`;
        }
    }

    function createBookCard(book) {
        return `
            <div class="group bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden card-hover flex flex-col h-full relative transition-colors">
                <div class="h-64 bg-slate-100 dark:bg-slate-700 relative overflow-hidden">
                    <img src="${book.coverImage && book.coverImage !== 'no-photo.jpg' ? book.coverImage : 'https://via.placeholder.com/300x400?text=No+Image'}" 
                            alt="${book.title}" 
                            onerror="this.src='data:image/svg+xml;base64,'"
                            class="w-full h-full object-contain p-2 transform group-hover:scale-105 transition-transform duration-500">
                    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                            <span class="text-white text-xs font-medium bg-black/30 backdrop-blur-md px-2 py-1 rounded-md border border-white/20">${book.category || 'Genre'}</span>
                    </div>
                    ${book.stock <= 0 ? '<div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm flex items-center justify-center"><span class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold shadow-lg transform -rotate-12 border-2 border-white">SOLD OUT</span></div>' : ''}
                </div>
                <div class="p-5 flex-grow flex flex-col">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1 leading-snug group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors line-clamp-1" title="${book.title}">${book.title}</h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mb-3 font-medium">by ${book.author}</p>
                    <p class="text-slate-600 dark:text-slate-300 text-sm line-clamp-3 mb-4 flex-grow leading-relaxed">${book.description}</p>
                    <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100 dark:border-slate-700">
                        <div class="flex flex-col">
                            <span class="text-xs text-slate-400 dark:text-slate-500 uppercase tracking-wider font-semibold">Price</span>
                            <span class="text-2xl font-bold text-slate-900 dark:text-white">$${book.price}</span>
                        </div>
                        <button onclick="addToCart('${book._id}')" 
                                class="bg-brand-50 dark:bg-slate-700 text-brand-600 dark:text-brand-400 hover:bg-brand-600 dark:hover:bg-brand-500 hover:text-white dark:hover:text-white p-3 rounded-xl transition-all shadow-sm hover:shadow-brand-500/30 auth-visible disabled:opacity-50 disabled:cursor-not-allowed group/btn"
                                ${book.stock <= 0 ? 'disabled' : ''}>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover/btn:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>`;
    }

    function renderTrending(allBooks) {
        // Randomize and pick 5-7 books
        const shuffled = [...allBooks].sort(() => 0.5 - Math.random());
        const trendingBooks = shuffled.slice(0, 7);
        const container = document.getElementById('trendingGrid');

        if (!container) return;

        container.innerHTML = trendingBooks.map(book => `
            <div class="min-w-[280px] md:min-w-[320px] bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-lg border border-slate-100 dark:border-slate-700 snap-center transition-transform hover:-translate-y-2 hover:shadow-xl duration-300 cursor-pointer flex flex-col h-full group">
                <div class="relative h-48 rounded-xl overflow-hidden mb-4 group/img">
                    <img src="${book.coverImage && book.coverImage !== 'no-photo.jpg' ? book.coverImage : 'https://via.placeholder.com/300x200'}" 
                         alt="${book.title}"
                         onerror="this.src='data:image/svg+xml;base64,'"
                         class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <span class="absolute bottom-3 left-3 bg-white/20 backdrop-blur-md text-white text-xs font-bold px-2 py-1 rounded">Trending</span>
                </div>
                <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-1 line-clamp-1" title="${book.title}">${book.title}</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-3 line-clamp-1">By ${book.author}</p>
                <div class="flex justify-between items-center mt-auto">
                    <span class="text-xl font-bold text-brand-600 dark:text-brand-400">$${book.price}</span>
                    <button onclick="addToCart('${book._id}')" class="p-2 rounded-full bg-slate-100 dark:bg-slate-700 hover:bg-brand-500 hover:text-white transition-colors auth-visible">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    </button>
                </div>
            </div>
        `).join('');

        checkAuthStatus();
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('categoryFilter').value = '';
        loadBooks();
    }

    async function addToCart(bookId) {
        const token = localStorage.getItem('token');
        if (!token) {
            // Store return url
            localStorage.setItem('returnUrl', window.location.pathname);
            window.location.href = '/login';
            return;
        }

        try {
            await axios.post(`http://${window.location.hostname}:5000/api/cart`, {
                bookId,
                quantity: 1
            }, {
                headers: { Authorization: `Bearer \${token}` }
            });
            // Show toast instead of alert ideally, but for now
            const btn = event.currentTarget || document.querySelector(`button[onclick*="${bookId}"]`);
            if (btn) {
                const originalContent = btn.innerHTML;
                btn.innerHTML = '<svg class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
                setTimeout(() => btn.innerHTML = originalContent, 2000);
            }
        } catch (error) {
            console.error('Add to cart failed:', error);
            alert('Failed to add to cart: ' + (error.response?.data?.message || error.message));
        }
    }

    function checkAuthStatus() {
        const token = localStorage.getItem('token');
        if (!token) {
            document.querySelectorAll('.auth-visible').forEach(el => el.style.display = 'none');
        } else {
            document.querySelectorAll('.auth-visible').forEach(el => el.style.display = 'block'); // or inline-flex depending on element
        }
    }

    function debounce(func, timeout = 300) {
        let timer;
        return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
        };
    }

    function toggleFilters() {
        const content = document.getElementById('filterContent');
        const icon = document.getElementById('filterIcon');

        if (window.innerWidth < 1024) {
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                content.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }
    }

    async function subscribeNewsletter() {
        const emailInput = document.getElementById('newsletterEmail');
        const btn = document.getElementById('newsletterBtn');
        const email = emailInput.value;

        if (!email) return;

        const originalText = btn.textContent;
        btn.textContent = 'Sending...';
        btn.disabled = true;

        try {
            const API_BASE = `http://${window.location.hostname}:5000/api`;
            const response = await axios.post(`${API_BASE}/newsletter/subscribe`, { email });

            if (response.data.success) {
                alert(response.data.message); // Or use a nicer toast if available
                emailInput.value = '';
                if (response.data.preview) {
                    console.log('Email Preview:', response.data.preview);
                    // Link removed from UI as requested
                }
            } else {
                alert(response.data.message || 'Subscription failed. Please try again.');
            }
        } catch (error) {
            console.error('Newsletter error:', error);
            const msg = error.response?.data?.message || error.response?.data?.error || 'Failed to subscribe. Please try again later.';
            alert(msg);
        } finally {
            btn.textContent = originalText;
            btn.disabled = false;
        }
    }
</script>